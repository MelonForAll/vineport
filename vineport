#!/bin/bash
# vineport — Game launcher CLI for Vineport
# Manages Steam and Epic Games, per-game profiles, and launches with custom Wine settings.
#
# Usage:
#   vineport games                    List installed Steam games
#   vineport launch <appid|name>      Launch a game
#   vineport info <appid|name>        Show game details & compatibility
#   vineport profile <appid> [opts]   Manage per-game Wine settings
#   vineport steam                    Launch Steam client
#
# Epic Games (via Legendary):
#   vineport epic login               Log in to Epic Games
#   vineport epic games               List your Epic Games library
#   vineport epic install <name>      Install an Epic game
#   vineport epic launch <name>       Launch an Epic game
#   vineport epic info <name>         Show Epic game details
#   vineport epic update <name>       Update an Epic game
#   vineport epic uninstall <name>    Uninstall an Epic game

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Detect .app bundle context
if [[ "${SCRIPT_DIR}" == *".app/Contents/Resources"* ]]; then
    SUPPORT_DIR="${HOME}/Library/Application Support/Vineport"
    WINE_DIR="${SUPPORT_DIR}/wine"
else
    WINE_DIR="${SCRIPT_DIR}/wine"
    # Fall back to the GUI's Application Support install (older GUI builds put
    # Wine there even for a git clone).
    if [[ ! -x "${WINE_DIR}/bin/wine" \
          && -x "${HOME}/Library/Application Support/Vineport/wine/bin/wine" ]]; then
        WINE_DIR="${HOME}/Library/Application Support/Vineport/wine"
    fi
fi

WINE_BIN="${WINE_DIR}/bin"
DEFAULT_PREFIX="$HOME/Library/Application Support/Vineport"
WINEPREFIX="${WINEPREFIX:-${DEFAULT_PREFIX}}"
STEAMAPPS="${WINEPREFIX}/drive_c/Program Files (x86)/Steam/steamapps"
PROFILES_DIR="${HOME}/.config/vineport"
PROFILES_FILE="${PROFILES_DIR}/profiles.json"

# ── Colors ────────────────────────────────────────────────────────────
# Only colorize when stdout is a terminal — piped/redirected output stays clean.
if [[ -t 1 ]]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[0;33m'
    CYAN='\033[0;36m'
    BOLD='\033[1m'
    DIM='\033[2m'
    NC='\033[0m'
else
    RED='' GREEN='' YELLOW='' CYAN='' BOLD='' DIM='' NC=''
fi

# ── VDF Parser ────────────────────────────────────────────────────────
# Extracts a top-level key from a VDF/ACF file
vdf_get() {
    local file="$1" key="$2"
    awk -v key="\"${key}\"" '
        $1 == key {
            # Remove key and surrounding tabs/spaces, then strip quotes
            sub(/^[[:space:]]*"[^"]*"[[:space:]]*"/, "")
            sub(/"[[:space:]]*$/, "")
            print
            exit
        }
    ' "$file"
}

# ── Profiles ──────────────────────────────────────────────────────────
init_profiles() {
    mkdir -p "${PROFILES_DIR}"
    if [[ ! -f "${PROFILES_FILE}" ]]; then
        cat > "${PROFILES_FILE}" << 'ENDJSON'
{
  "default": {
    "dxvk": false,
    "env": {},
    "wine_args": "",
    "game_args": ""
  },
  "games": {}
}
ENDJSON
    fi
}

# Read a profile value using python3 (available on all macOS).
# Values are passed via the environment, never interpolated into Python source,
# so quotes/backslashes in inputs can't break or inject into the script.
profile_get() {
    local appid="$1" key="$2"
    VP_FILE="${PROFILES_FILE}" VP_APPID="$appid" VP_KEY="$key" python3 -c '
import json, os
with open(os.environ["VP_FILE"]) as f:
    data = json.load(f)
games = data.get("games", {})
profile = games.get(os.environ["VP_APPID"], data.get("default", {}))
key = os.environ["VP_KEY"]
val = profile.get(key, data.get("default", {}).get(key, ""))
if isinstance(val, dict):
    print(json.dumps(val))
elif isinstance(val, bool):
    print("true" if val else "false")
else:
    print(val)
' 2>/dev/null
}

# Set a profile value
profile_set() {
    local appid="$1" key="$2" value="$3"
    VP_FILE="${PROFILES_FILE}" VP_APPID="$appid" VP_KEY="$key" VP_VALUE="$value" python3 -c '
import json, os
appid = os.environ["VP_APPID"]; key = os.environ["VP_KEY"]; value = os.environ["VP_VALUE"]
with open(os.environ["VP_FILE"]) as f:
    data = json.load(f)
if "games" not in data:
    data["games"] = {}
if appid not in data["games"]:
    data["games"][appid] = dict(data.get("default", {}))
# Type coercion
val = value
if val.lower() == "true": val = True
elif val.lower() == "false": val = False
elif val.isdigit(): val = int(val)
data["games"][appid][key] = val
with open(os.environ["VP_FILE"], "w") as f:
    json.dump(data, f, indent=2)
print("Set %s=%s for AppID %s" % (key, value, appid))
'
}

# Set an environment variable in a game's profile
profile_set_env() {
    local appid="$1" env_key="$2" env_val="$3"
    VP_FILE="${PROFILES_FILE}" VP_APPID="$appid" VP_EKEY="$env_key" VP_EVAL="$env_val" python3 -c '
import json, os
appid = os.environ["VP_APPID"]; ekey = os.environ["VP_EKEY"]; eval_ = os.environ["VP_EVAL"]
with open(os.environ["VP_FILE"]) as f:
    data = json.load(f)
if "games" not in data:
    data["games"] = {}
if appid not in data["games"]:
    data["games"][appid] = dict(data.get("default", {}))
if "env" not in data["games"][appid] or not isinstance(data["games"][appid]["env"], dict):
    data["games"][appid]["env"] = {}
data["games"][appid]["env"][ekey] = eval_
with open(os.environ["VP_FILE"], "w") as f:
    json.dump(data, f, indent=2)
print("Set env %s=%s for AppID %s" % (ekey, eval_, appid))
'
}

# Reset a game's profile
profile_reset() {
    local appid="$1"
    VP_FILE="${PROFILES_FILE}" VP_APPID="$appid" python3 -c '
import json, os
appid = os.environ["VP_APPID"]
with open(os.environ["VP_FILE"]) as f:
    data = json.load(f)
if "games" in data and appid in data["games"]:
    del data["games"][appid]
with open(os.environ["VP_FILE"], "w") as f:
    json.dump(data, f, indent=2)
print("Reset profile for AppID %s" % appid)
'
}

# Get all env vars for a game as KEY=VALUE lines
profile_get_env() {
    local appid="$1"
    VP_FILE="${PROFILES_FILE}" VP_APPID="$appid" python3 -c '
import json, os
with open(os.environ["VP_FILE"]) as f:
    data = json.load(f)
games = data.get("games", {})
default_env = data.get("default", {}).get("env", {})
game_env = games.get(os.environ["VP_APPID"], {}).get("env", {})
merged = {**default_env, **game_env}
for k, v in merged.items():
    print("%s=%s" % (k, v))
' 2>/dev/null
}

# ── Game Discovery ────────────────────────────────────────────────────
list_games() {
    if [[ ! -d "${STEAMAPPS}" ]]; then
        echo -e "${RED}Steam not installed yet. Run ./launch-steam.sh first.${NC}" >&2
        exit 1
    fi

    local count=0
    printf "${BOLD}%-10s %-40s %10s  %s${NC}\n" "AppID" "Name" "Size" "Status"
    printf "%-10s %-40s %10s  %s\n" "─────" "────────────────────────────" "────────" "──────"

    for manifest in "${STEAMAPPS}"/appmanifest_*.acf; do
        [[ -f "$manifest" ]] || continue

        local appid name size state installdir
        appid=$(vdf_get "$manifest" "appid")
        name=$(vdf_get "$manifest" "name")
        size=$(vdf_get "$manifest" "SizeOnDisk")
        state=$(vdf_get "$manifest" "StateFlags")
        installdir=$(vdf_get "$manifest" "installdir")

        # Skip redistributables
        [[ "$name" == *"Redistributable"* ]] && continue
        [[ "$name" == *"Proton"* ]] && continue

        # Format size
        local size_fmt
        if [[ -n "$size" ]] && [[ "$size" -gt 0 ]]; then
            if [[ "$size" -gt 1073741824 ]]; then
                size_fmt="$(( size / 1073741824 )) GB"
            elif [[ "$size" -gt 1048576 ]]; then
                size_fmt="$(( size / 1048576 )) MB"
            else
                size_fmt="$(( size / 1024 )) KB"
            fi
        else
            size_fmt="—"
        fi

        # Status
        local status_str
        if [[ "$state" == "4" ]]; then
            status_str="${GREEN}installed${NC}"
        elif [[ "$state" == "6" ]]; then
            status_str="${YELLOW}updating${NC}"
        elif [[ "$state" == "1026" ]]; then
            status_str="${YELLOW}downloading${NC}"
        else
            status_str="${DIM}state:${state}${NC}"
        fi

        # Profile indicator
        local profile_mark=""
        if [[ -f "${PROFILES_FILE}" ]]; then
            if VP_FILE="${PROFILES_FILE}" VP_APPID="$appid" python3 -c '
import json, os
with open(os.environ["VP_FILE"]) as f:
    d = json.load(f)
exit(0 if os.environ["VP_APPID"] in d.get("games", {}) else 1)
' 2>/dev/null; then
                profile_mark=" ${CYAN}[profile]${NC}"
            fi
        fi

        printf "%-10s %-40s %10s  " "$appid" "$name" "$size_fmt"
        echo -e "${status_str}${profile_mark}"
        count=$((count + 1))
    done

    echo ""
    echo -e "${DIM}${count} game(s) found. Use 'vineport launch <appid>' to play.${NC}"
}

# Find AppID by name (partial, case-insensitive match)
find_appid_by_name() {
    local search="$1"
    local search_lower
    search_lower=$(echo "$search" | tr '[:upper:]' '[:lower:]')

    for manifest in "${STEAMAPPS}"/appmanifest_*.acf; do
        [[ -f "$manifest" ]] || continue
        local name appid
        name=$(vdf_get "$manifest" "name")
        appid=$(vdf_get "$manifest" "appid")
        local name_lower
        name_lower=$(echo "$name" | tr '[:upper:]' '[:lower:]')
        if [[ "$name_lower" == *"$search_lower"* ]]; then
            echo "$appid"
            return 0
        fi
    done
    return 1
}

# ── Game Info ─────────────────────────────────────────────────────────
show_info() {
    local appid="$1"
    local manifest="${STEAMAPPS}/appmanifest_${appid}.acf"

    if [[ ! -f "$manifest" ]]; then
        echo -e "${RED}Game AppID ${appid} not found.${NC}" >&2
        exit 1
    fi

    local name installdir size
    name=$(vdf_get "$manifest" "name")
    installdir=$(vdf_get "$manifest" "installdir")
    size=$(vdf_get "$manifest" "SizeOnDisk")

    echo -e "${BOLD}${name}${NC} (AppID: ${appid})"
    echo ""
    echo -e "  Install dir: ${STEAMAPPS}/common/${installdir}"

    if [[ -n "$size" ]] && [[ "$size" -gt 0 ]]; then
        local size_fmt
        if [[ "$size" -gt 1073741824 ]]; then
            size_fmt="$(( size / 1073741824 )) GB"
        elif [[ "$size" -gt 1048576 ]]; then
            size_fmt="$(( size / 1048576 )) MB"
        else
            size_fmt="$(( size / 1024 )) KB"
        fi
        echo -e "  Size on disk: ${size_fmt}"
    fi

    # Check for known compatibility issues
    local has_eac=0 has_battleye=0
    local gamedir="${STEAMAPPS}/common/${installdir}"
    if [[ -d "$gamedir" ]]; then
        if find "$gamedir" -maxdepth 3 -iname "*EasyAntiCheat*" -print -quit 2>/dev/null | grep -q .; then
            has_eac=1
        fi
        if find "$gamedir" -maxdepth 3 -iname "*BattlEye*" -print -quit 2>/dev/null | grep -q .; then
            has_battleye=1
        fi
    fi

    # Detect anti-cheat mode (user-mode vs kernel-mode)
    local eac_mode="" battleye_mode=""
    if [[ $has_eac -eq 1 ]] && [[ -d "$gamedir" ]]; then
        # Check for EAC config files that indicate mode
        if find "$gamedir" -maxdepth 3 -name "EasyAntiCheat_EOS_Setup.exe" -print -quit 2>/dev/null | grep -q .; then
            eac_mode="EOS (newer, user-mode possible)"
        elif find "$gamedir" -maxdepth 3 -name "EasyAntiCheat_Setup.exe" -print -quit 2>/dev/null | grep -q .; then
            eac_mode="Legacy (likely kernel-mode)"
        fi
        # Check for Linux/Proton EAC support (easyanticheat_x64.so presence)
        if find "$gamedir" -maxdepth 3 -name "easyanticheat_x64.so" -print -quit 2>/dev/null | grep -q .; then
            eac_mode="${eac_mode:+${eac_mode}, }Linux/Proton runtime present"
        fi
    fi
    if [[ $has_battleye -eq 1 ]] && [[ -d "$gamedir" ]]; then
        if find "$gamedir" -maxdepth 3 -name "BEService_x64.exe" -print -quit 2>/dev/null | grep -q .; then
            battleye_mode="Service-based (kernel driver)"
        fi
    fi

    echo ""
    echo -e "  ${BOLD}Anti-Cheat:${NC}"
    if [[ $has_eac -eq 1 ]]; then
        echo -e "    ${RED}EasyAntiCheat detected${NC}"
        if [[ -n "$eac_mode" ]]; then
            echo -e "    Mode: ${eac_mode}"
        fi
        echo -e "    Status: Online multiplayer likely won't work"
        echo -e "    Note: Games with EOS EAC + Linux/Proton support are most"
        echo -e "          likely to work with future anti-cheat patches."
    fi
    if [[ $has_battleye -eq 1 ]]; then
        echo -e "    ${RED}BattlEye detected${NC}"
        if [[ -n "$battleye_mode" ]]; then
            echo -e "    Mode: ${battleye_mode}"
        fi
        echo -e "    Status: Online multiplayer likely won't work"
    fi
    if [[ $has_eac -eq 0 ]] && [[ $has_battleye -eq 0 ]]; then
        echo -e "    ${GREEN}No known anti-cheat detected${NC}"
    fi

    # Show profile if set
    echo ""
    echo -e "  ${BOLD}Profile:${NC}"
    if [[ -f "${PROFILES_FILE}" ]] && VP_FILE="${PROFILES_FILE}" VP_APPID="$appid" python3 -c '
import json, os
with open(os.environ["VP_FILE"]) as f:
    d = json.load(f)
exit(0 if os.environ["VP_APPID"] in d.get("games", {}) else 1)
' 2>/dev/null; then
        local dxvk game_args env_vars
        dxvk=$(profile_get "$appid" "dxvk")
        game_args=$(profile_get "$appid" "game_args")
        env_vars=$(profile_get_env "$appid")
        echo -e "    DXVK: ${dxvk}"
        [[ -n "$game_args" ]] && echo -e "    Game args: ${game_args}"
        if [[ -n "$env_vars" ]]; then
            echo -e "    Environment:"
            echo "$env_vars" | while read -r line; do
                echo -e "      ${line}"
            done
        fi
    else
        echo -e "    ${DIM}Using defaults. Set with: vineport profile ${appid} --set KEY=VALUE${NC}"
    fi
}

# ── Game Launch ───────────────────────────────────────────────────────
launch_game() {
    local appid="$1"
    local manifest="${STEAMAPPS}/appmanifest_${appid}.acf"

    if [[ ! -f "$manifest" ]]; then
        echo -e "${RED}Game AppID ${appid} not found.${NC}" >&2
        exit 1
    fi

    local name
    name=$(vdf_get "$manifest" "name")
    echo -e "${BOLD}Launching ${name}${NC} (AppID: ${appid})..."

    # Apply per-game profile environment variables
    init_profiles
    local env_vars
    env_vars=$(profile_get_env "$appid")
    if [[ -n "$env_vars" ]]; then
        while IFS= read -r line; do
            export "$line"
        done <<< "$env_vars"
    fi

    # Check DXVK setting
    local dxvk
    dxvk=$(profile_get "$appid" "dxvk")
    if [[ "$dxvk" == "true" ]]; then
        export WINEDLLOVERRIDES="d3d11,d3d10core,dxgi,d3d9=n,b;${WINEDLLOVERRIDES:-}"
    fi

    # Get extra game args from profile
    local game_args
    game_args=$(profile_get "$appid" "game_args")

    # Launch via Steam's protocol (lets Steam handle the game launch)
    exec "${SCRIPT_DIR}/launch-steam.sh" -applaunch "$appid" $game_args
}

# ── Profile Management ────────────────────────────────────────────────
show_profile() {
    local appid="$1"
    shift

    init_profiles

    # Handle flags
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --set)
                if [[ -z "${2:-}" ]]; then
                    echo "Usage: vineport profile <appid> --set KEY=VALUE" >&2
                    exit 1
                fi
                local kv="$2"
                local key="${kv%%=*}"
                local value="${kv#*=}"
                if [[ "$key" == "env."* ]]; then
                    local env_key="${key#env.}"
                    profile_set_env "$appid" "$env_key" "$value"
                else
                    profile_set "$appid" "$key" "$value"
                fi
                shift 2
                return
                ;;
            --reset)
                profile_reset "$appid"
                shift
                return
                ;;
            *)
                shift
                ;;
        esac
    done

    # Show current profile
    local name=""
    local manifest="${STEAMAPPS}/appmanifest_${appid}.acf"
    [[ -f "$manifest" ]] && name=$(vdf_get "$manifest" "name")

    echo -e "${BOLD}Profile for ${name:-AppID $appid}${NC}"
    echo ""
    VP_FILE="${PROFILES_FILE}" VP_APPID="$appid" python3 -c '
import json, os
appid = os.environ["VP_APPID"]
with open(os.environ["VP_FILE"]) as f:
    data = json.load(f)
default = data.get("default", {})
game = data.get("games", {}).get(appid, None)
if game:
    print("  Custom profile:")
    print(json.dumps(game, indent=4).replace("{", "  {").replace("}", "  }"))
else:
    print("  Using defaults:")
    print(json.dumps(default, indent=4).replace("{", "  {").replace("}", "  }"))
print()
print("Set options with:")
print("  vineport profile %s --set dxvk=true" % appid)
print("  vineport profile %s --set game_args=\"-windowed\"" % appid)
print("  vineport profile %s --set env.DXVK_HUD=fps" % appid)
print("  vineport profile %s --set env.WINEDEBUG=+d3d" % appid)
'
}

# ── Epic Games (via Legendary) ────────────────────────────────────────

LEGENDARY_CMD=""
EPIC_INSTALL_DIR="${WINEPREFIX}/drive_c/Epic Games"

# Find or install legendary
find_legendary() {
    if [[ -n "$LEGENDARY_CMD" ]]; then return 0; fi

    # Check common locations. Globs cover whatever Python version pip used —
    # hardcoded version lists rot (3.13/3.14 installs were silently missed).
    for cmd in legendary legendary-gl "$HOME/.local/bin/legendary" \
               "$HOME"/Library/Python/*/bin/legendary \
               /Library/Frameworks/Python.framework/Versions/*/bin/legendary \
               /opt/homebrew/bin/legendary /usr/local/bin/legendary; do
        if command -v "$cmd" &>/dev/null || [[ -x "$cmd" ]]; then
            LEGENDARY_CMD="$cmd"
            return 0
        fi
    done

    # Try python module
    if python3 -m legendary --help &>/dev/null 2>&1; then
        LEGENDARY_CMD="python3 -m legendary"
        return 0
    fi

    return 1
}

ensure_legendary() {
    if find_legendary; then return 0; fi

    echo -e "${YELLOW}Legendary (Epic Games CLI) not found.${NC}"
    echo ""
    # pipx when available; otherwise pip --user. A bare `pip3 install` fails
    # outright on Homebrew Python (PEP 668 externally-managed environment).
    if command -v pipx &>/dev/null; then
        echo "Installing via pipx..."
        pipx install legendary-gl 2>&1 | tail -3 || true
    else
        echo "Installing via pip..."
        pip3 install --user legendary-gl 2>&1 | tail -3 || true
    fi

    if find_legendary; then
        echo -e "${GREEN}Legendary installed successfully.${NC}"
        return 0
    else
        echo -e "${RED}Failed to install Legendary.${NC}" >&2
        echo "Try manually: pip3 install --user legendary-gl" >&2
        echo "  (or on Homebrew Python: brew install pipx && pipx install legendary-gl)" >&2
        return 1
    fi
}

# Resolve an Epic game's install directory. Legendary installs into a folder
# derived from the game's TITLE (e.g. 'rocketleague'), not its app name, so
# prefer the real install_path recorded in ~/.config/legendary/installed.json
# (keyed by app name). Fall back to the old '<base>/<app name>' layout, then a
# case/space-insensitive match among the install dir's subfolders.
epic_game_dir() {
    local game_name="$1"
    local dir=""

    dir=$(VP_APP="$game_name" python3 -c '
import json, os
with open(os.path.expanduser("~/.config/legendary/installed.json")) as f:
    data = json.load(f)
print(data.get(os.environ["VP_APP"], {}).get("install_path", ""))
' 2>/dev/null) || dir=""
    if [[ -n "$dir" && -d "$dir" ]]; then
        echo "$dir"
        return 0
    fi

    # Legacy app-name layout
    if [[ -d "${EPIC_INSTALL_DIR}/${game_name}" ]]; then
        echo "${EPIC_INSTALL_DIR}/${game_name}"
        return 0
    fi

    # Title-derived folder (compare ignoring case and non-alphanumerics)
    local want cand base
    want=$(echo "$game_name" | tr '[:upper:]' '[:lower:]' | tr -cd '[:alnum:]')
    if [[ -n "$want" ]]; then
        for cand in "${EPIC_INSTALL_DIR}"/*/; do
            [[ -d "$cand" ]] || continue
            base=$(basename "$cand" | tr '[:upper:]' '[:lower:]' | tr -cd '[:alnum:]')
            if [[ "$base" == "$want" ]]; then
                echo "${cand%/}"
                return 0
            fi
        done
    fi

    # Nothing found — return the old pattern so callers behave as before
    echo "${EPIC_INSTALL_DIR}/${game_name}"
}

# Set up Wine + renderer environment for Epic game launches.
# Sets EPIC_WINE (the wine binary legendary should use) and EPIC_USING_GPTK.
# Prefers Apple's Game Porting Toolkit (D3DMetal) when installed — reliable for
# D3D11 and D3D12 — else the bundled Wine (DXVK). VINEPORT_NO_GPTK=1 forces bundled.
setup_epic_wine_env() {
    export WINEPREFIX
    export WINEARCH=win64
    export WINEDEBUG="${WINEDEBUG:--all}"
    export WINEMSYNC=1
    export WINEESYNC=1

    local gptk_wine="/Applications/Game Porting Toolkit.app/Contents/Resources/wine/bin/wine64"
    if [[ -x "$gptk_wine" && "${VINEPORT_NO_GPTK:-0}" != "1" ]]; then
        EPIC_WINE="$gptk_wine"
        EPIC_USING_GPTK=1
        # Force builtin D3DMetal; drop bundled dylib/datadir so GPTK uses its own
        # and not the prefix's persistent DXVK override.
        export WINEDLLOVERRIDES="d3d9,d3d10,d3d10core,d3d11,d3d12,d3d12core,dxgi=b"
        unset DYLD_LIBRARY_PATH
        unset WINEDATADIR
        export PATH="$(dirname "$gptk_wine"):${PATH}"
        # Dedicated GPTK prefix, same as launch-steam-gptk.sh: GPTK's Wine (7.7)
        # must never reconfigure the bundled Wine (11.7) prefix. The Epic Games
        # library is symlinked in, so C:\ paths are unchanged. (Game files still
        # live under the shared prefix; EPIC_INSTALL_DIR is unaffected.)
        # shellcheck source=common.sh
        source "${SCRIPT_DIR}/common.sh"
        vineport_gptk_prefix "${WINEPREFIX}" "$gptk_wine"
        WINEPREFIX="${GPTK_PREFIX}"
        export WINEPREFIX
        export WINESERVER="$(dirname "$gptk_wine")/wineserver"
        echo -e "  ${DIM}Rendering via Game Porting Toolkit (D3DMetal).${NC}"
    else
        EPIC_WINE="${WINE_BIN}/wine"
        EPIC_USING_GPTK=0
        export WINEDATADIR="${WINE_DIR}/share/wine"
        export DYLD_LIBRARY_PATH="${WINE_DIR}/lib"
        export PATH="${WINE_BIN}:${PATH}"
        # Pin our own wineserver — a stale inherited WINESERVER (e.g. from a
        # GPTK shell) would make wine talk to the wrong server.
        export WINESERVER="${WINE_BIN}/wineserver"
    fi
}

epic_login() {
    ensure_legendary || return 1
    echo -e "${BOLD}Logging in to Epic Games...${NC}"
    echo ""
    $LEGENDARY_CMD auth
}

epic_list_games() {
    ensure_legendary || return 1
    echo -e "${BOLD}Epic Games Library${NC}"
    echo ""
    $LEGENDARY_CMD list 2>/dev/null
}

epic_install() {
    local game_name="$1"
    ensure_legendary || return 1

    # Create Epic Games install directory inside Wine prefix
    mkdir -p "${EPIC_INSTALL_DIR}"

    echo -e "${BOLD}Installing ${game_name}...${NC}"
    echo -e "  Install path: ${EPIC_INSTALL_DIR}/${game_name}"
    echo ""

    # Legendary installs the Windows version of the game
    $LEGENDARY_CMD install "$game_name" \
        --base-path "${EPIC_INSTALL_DIR}" \
        --platform Windows
}

epic_launch() {
    local game_name="$1"
    ensure_legendary || return 1

    echo -e "${BOLD}Launching Epic game: ${game_name}${NC}"

    setup_epic_wine_env

    # Apply per-game profile if set (use epic: prefix for epic game IDs)
    local profile_id="epic:${game_name}"
    local env_vars
    env_vars=$(profile_get_env "$profile_id" 2>/dev/null || true)
    if [[ -n "$env_vars" ]]; then
        while IFS= read -r line; do
            [[ -n "$line" ]] && export "$line"
        done <<< "$env_vars"
    fi

    # Check DXVK setting (ignored under GPTK, which renders via D3DMetal — a native
    # DXVK override there would need Vulkan and break the launch).
    local dxvk
    dxvk=$(profile_get "$profile_id" "dxvk" 2>/dev/null || echo "false")
    if [[ "$dxvk" == "true" && "${EPIC_USING_GPTK:-0}" != "1" ]]; then
        export WINEDLLOVERRIDES="d3d11,d3d10core,dxgi,d3d9=n,b;${WINEDLLOVERRIDES:-}"
    fi

    # Get extra game args from profile
    local game_args
    game_args=$(profile_get "$profile_id" "game_args" 2>/dev/null || true)

    echo ""

    # If the game bundles Easy Anti-Cheat, run with the EOS null client so it
    # launches for offline/singleplayer play. (Online anti-cheat won't connect.)
    local gamedir
    gamedir=$(epic_game_dir "$game_name")
    if find "$gamedir" -maxdepth 4 -iname "*EasyAntiCheat*" -print -quit 2>/dev/null | grep -q .; then
        export EOS_USE_ANTICHEATCLIENTNULL=1
        echo -e "  ${DIM}Anti-cheat detected — launching offline (EOS null client).${NC}"
    fi

    # Cloud saves: pull the latest before launch. --accept-path confirms the
    # computed save path non-interactively — a bare -y makes legendary silently
    # SKIP any game whose path was never confirmed. Best-effort, but surface
    # failures instead of hiding them behind an affirmative message.
    echo -e "  ${DIM}Syncing cloud saves...${NC}"
    local sync_out
    sync_out=$($LEGENDARY_CMD -y sync-saves --accept-path "$game_name" 2>&1) \
        || echo -e "  ${YELLOW}Cloud-save sync failed: $(printf '%s\n' "$sync_out" | tail -1)${NC}"

    # Use legendary to launch, telling it which Wine to use (GPTK/D3DMetal when
    # available, else bundled) and our prefix.
    local launch_rc=0
    $LEGENDARY_CMD launch "$game_name" \
        --wine "${EPIC_WINE}" \
        --wine-prefix "${WINEPREFIX}" \
        $game_args \
        2>&1 || launch_rc=$?

    if [[ $launch_rc -eq 0 ]]; then
        # legendary returns as soon as the game process SPAWNS — wait for the
        # game's own processes (matched by install-dir name) before uploading.
        # Waiting on the whole prefix (wineserver -w) would also wait on a
        # Steam client sharing it, stalling the upload until Steam quits.
        local gd_pat waited=0
        gd_pat=$(printf '%s' "$(basename "$gamedir")" | sed 's/[][\.*^$()+?{}|]/\\&/g')
        # Exclude our own process — the app name can match the folder name.
        while ! pgrep -f "$gd_pat" 2>/dev/null | grep -qv "^$$\$" \
              && [[ $waited -lt 30 ]]; do
            sleep 2
            waited=$((waited + 2))
        done
        while pgrep -f "$gd_pat" 2>/dev/null | grep -qv "^$$\$"; do
            sleep 5
        done
        echo ""
        echo -e "  ${DIM}Syncing cloud saves back up...${NC}"
        sync_out=$($LEGENDARY_CMD -y sync-saves --accept-path "$game_name" 2>&1) \
            || echo -e "  ${YELLOW}Cloud-save sync failed: $(printf '%s\n' "$sync_out" | tail -1)${NC}"
    fi
    return $launch_rc
}

epic_info() {
    local game_name="$1"
    ensure_legendary || return 1

    echo -e "${BOLD}Epic Game Info: ${game_name}${NC}"
    echo ""
    # legendary exits 0 even for unknown games — detect by output instead.
    local info_out
    info_out=$($LEGENDARY_CMD info "$game_name" 2>/dev/null || true)
    if [[ -z "$info_out" || "$info_out" == *"No game information available"* ]]; then
        echo -e "${RED}No Epic game named '${game_name}' in your library.${NC}" >&2
        echo "  List available games with: vineport epic games" >&2
        return 1
    fi
    printf '%s\n' "$info_out"

    # Check for EAC in the installed game
    local game_dir
    game_dir=$(epic_game_dir "$game_name")
    if [[ -d "$game_dir" ]]; then
        echo ""
        echo -e "  ${BOLD}Anti-Cheat:${NC}"
        local has_eac=0 has_battleye=0
        if find "$game_dir" -maxdepth 4 -iname "*EasyAntiCheat*" -print -quit 2>/dev/null | grep -q .; then
            has_eac=1
        fi
        if find "$game_dir" -maxdepth 4 -iname "*BattlEye*" -print -quit 2>/dev/null | grep -q .; then
            has_battleye=1
        fi

        if [[ $has_eac -eq 1 ]]; then
            echo -e "    ${RED}EasyAntiCheat detected${NC}"
            # Check for EOS vs legacy
            if find "$game_dir" -maxdepth 4 -name "EasyAntiCheat_EOS_Setup.exe" -print -quit 2>/dev/null | grep -q .; then
                echo -e "    Mode: EOS (newer, user-mode)"
            fi
            echo ""
            echo -e "    EAC files:"
            find "$game_dir" -maxdepth 4 \( -iname "*EasyAntiCheat*" -o -iname "*eac*" \) 2>/dev/null | while IFS= read -r f; do
                echo "      $(basename "$f")"
            done
        fi
        if [[ $has_battleye -eq 1 ]]; then
            echo -e "    ${RED}BattlEye detected${NC}"
        fi
        if [[ $has_eac -eq 0 ]] && [[ $has_battleye -eq 0 ]]; then
            echo -e "    ${GREEN}No known anti-cheat detected${NC}"
        fi
    fi
}

epic_update() {
    local game_name="$1"
    ensure_legendary || return 1
    echo -e "${BOLD}Updating ${game_name}...${NC}"
    $LEGENDARY_CMD update "$game_name"
}

epic_uninstall() {
    local game_name="$1"
    ensure_legendary || return 1
    echo -e "${BOLD}Uninstalling ${game_name}...${NC}"
    $LEGENDARY_CMD uninstall "$game_name"
}

# Handle all epic subcommands
handle_epic() {
    local subcmd="${1:-}"
    shift 2>/dev/null || true

    case "$subcmd" in
        login|auth)
            epic_login
            ;;
        games|list|ls)
            epic_list_games
            ;;
        install)
            [[ -z "${1:-}" ]] && { echo "Usage: vineport epic install <game-name>"; exit 1; }
            epic_install "$1"
            ;;
        launch|play|run)
            [[ -z "${1:-}" ]] && { echo "Usage: vineport epic launch <game-name>"; exit 1; }
            epic_launch "$1"
            ;;
        info|show)
            [[ -z "${1:-}" ]] && { echo "Usage: vineport epic info <game-name>"; exit 1; }
            epic_info "$1"
            ;;
        update)
            [[ -z "${1:-}" ]] && { echo "Usage: vineport epic update <game-name>"; exit 1; }
            epic_update "$1"
            ;;
        uninstall|remove)
            [[ -z "${1:-}" ]] && { echo "Usage: vineport epic uninstall <game-name>"; exit 1; }
            epic_uninstall "$1"
            ;;
        help|--help|-h|"")
            echo -e "${BOLD}Vineport — Epic Games${NC} (via Legendary)"
            echo ""
            echo "Usage:"
            echo "  vineport epic login               Log in to Epic Games"
            echo "  vineport epic games               List your Epic library"
            echo "  vineport epic install <name>      Install a game"
            echo "  vineport epic launch <name>       Launch a game through Wine"
            echo "  vineport epic info <name>         Show game details & anti-cheat"
            echo "  vineport epic update <name>       Update a game"
            echo "  vineport epic uninstall <name>    Uninstall a game"
            echo ""
            echo "Game names use the Epic app name (e.g., 'Sugar' for Rocket League)."
            echo "Run 'vineport epic games' to see available names."
            ;;
        *)
            echo -e "${RED}Unknown epic command: ${subcmd}${NC}" >&2
            echo "Run 'vineport epic help' for usage."
            exit 1
            ;;
    esac
}

# ── Usage ─────────────────────────────────────────────────────────────
usage() {
    echo -e "${BOLD}Vineport${NC} — Wine game launcher for macOS"
    echo ""
    echo "Steam:"
    echo "  vineport games                         List installed Steam games"
    echo "  vineport launch <appid|name>           Launch a Steam game"
    echo "  vineport info <appid|name>             Show game details & compatibility"
    echo "  vineport profile <appid> [options]     Manage per-game Wine settings"
    echo "  vineport steam                         Launch Steam client"
    echo ""
    echo "Epic Games:"
    echo "  vineport epic login                    Log in to Epic Games"
    echo "  vineport epic games                    List your Epic library"
    echo "  vineport epic install <name>           Install an Epic game"
    echo "  vineport epic launch <name>            Launch an Epic game"
    echo "  vineport epic info <name>              Show Epic game details"
    echo "  (cloud saves sync automatically around 'epic launch')"
    echo ""
    echo "Winetricks:"
    echo "  vineport tricks [--gptk] <verb...>     Install redists/fonts into the prefix"
    echo "                                         (e.g. vcrun2022 corefonts d3dcompiler_47)"
    echo ""
    echo "Profile options:"
    echo "  --set KEY=VALUE    Set a profile value (dxvk, game_args, env.VAR)"
    echo "  --reset            Reset profile to defaults"
    echo ""
    echo "Examples:"
    echo "  vineport games"
    echo "  vineport launch 739630"
    echo "  vineport epic login"
    echo "  vineport epic install Sugar"
    echo "  vineport epic launch Sugar"
}

# ── Resolve AppID (number or name search) ─────────────────────────────
resolve_appid() {
    local input="$1"
    if [[ "$input" =~ ^[0-9]+$ ]]; then
        echo "$input"
    else
        local found
        found=$(find_appid_by_name "$input") || {
            echo -e "${RED}No game matching '${input}' found.${NC}" >&2
            exit 1
        }
        echo "$found"
    fi
}

# ── Winetricks ────────────────────────────────────────────────────────
# Pinned release, verified by checksum before first use (downloaded on demand).
WINETRICKS_VERSION="20260125"
WINETRICKS_SHA256="431f82fc74000e6c864409f1d8fb495d696c03928808e3e8acffc45179312a7b"
WINETRICKS_CACHE="${HOME}/.cache/vineport/winetricks-${WINETRICKS_VERSION}"

ensure_winetricks() {
    [[ -x "${WINETRICKS_CACHE}" ]] && return 0
    mkdir -p "$(dirname "${WINETRICKS_CACHE}")"
    echo "Downloading winetricks ${WINETRICKS_VERSION}..."
    local tmp sha
    tmp="$(mktemp /tmp/winetricks-XXXXXX)"
    if ! curl -fsL -o "$tmp" \
        "https://raw.githubusercontent.com/Winetricks/winetricks/${WINETRICKS_VERSION}/src/winetricks"; then
        echo -e "${RED}Failed to download winetricks.${NC}" >&2
        rm -f "$tmp"
        return 1
    fi
    sha="$(shasum -a 256 "$tmp" | awk '{print $1}')"
    if [[ "$sha" != "${WINETRICKS_SHA256}" ]]; then
        echo -e "${RED}winetricks checksum mismatch!${NC}" >&2
        echo "  Expected: ${WINETRICKS_SHA256}" >&2
        echo "  Got:      ${sha}" >&2
        rm -f "$tmp"
        return 1
    fi
    chmod +x "$tmp" && mv "$tmp" "${WINETRICKS_CACHE}"
}

tricks_cmd() {
    local use_gptk=0
    if [[ "${1:-}" == "--gptk" ]]; then
        use_gptk=1
        shift
    fi
    if [[ $# -eq 0 ]]; then
        echo "Usage: vineport tricks [--gptk] <verb...>"
        echo "  Common verbs: vcrun2022 corefonts d3dcompiler_47 dotnet48 dxvk"
        echo "  Full list:    vineport tricks list-all"
        echo "  --gptk        Apply to the dedicated GPTK prefix instead"
        return 1
    fi
    # A stray --gptk after the verbs would silently target the WRONG prefix.
    local a
    for a in "$@"; do
        if [[ "$a" == "--gptk" ]]; then
            echo -e "${RED}--gptk must come before the verbs.${NC}" >&2
            return 1
        fi
    done

    local prefix wine_bin wineserver_bin wrapper_env
    if [[ $use_gptk -eq 1 ]]; then
        # The GPTK prefix belongs to GPTK's Wine (7.7) — running the bundled
        # 11.7 against it is exactly the version churn the dedicated prefix
        # exists to prevent, and creating it here with 11.7 would also skip
        # the launchers' one-time init (users symlink included).
        local gptk_wine="/Applications/Game Porting Toolkit.app/Contents/Resources/wine/bin/wine64"
        if [[ ! -x "$gptk_wine" ]]; then
            echo -e "${RED}Game Porting Toolkit not found.${NC}" >&2
            echo "  Install it: brew install --cask gcenx/wine/game-porting-toolkit" >&2
            return 1
        fi
        # shellcheck source=common.sh
        source "${SCRIPT_DIR}/common.sh"
        vineport_gptk_prefix "${WINEPREFIX}" "$gptk_wine"
        prefix="${GPTK_PREFIX}"
        wine_bin="$gptk_wine"
        wineserver_bin="$(dirname "$gptk_wine")/wineserver"
        wrapper_env='unset DYLD_LIBRARY_PATH WINEDATADIR'
    else
        if [[ ! -x "${WINE_BIN}/wine" ]]; then
            echo -e "${RED}wine not found at ${WINE_BIN}/wine — run ./setup.sh first.${NC}" >&2
            return 1
        fi
        prefix="${WINEPREFIX}"
        wine_bin="${WINE_BIN}/wine"
        wineserver_bin="${WINE_BIN}/wineserver"
        wrapper_env="export WINEDATADIR=\"${WINE_DIR}/share/wine\"
export DYLD_LIBRARY_PATH=\"${WINE_DIR}/lib\""
    fi
    ensure_winetricks || return 1
    if ! command -v cabextract &>/dev/null; then
        echo -e "${YELLOW}Note: many winetricks verbs need cabextract: brew install cabextract${NC}"
    fi
    # SIP strips DYLD_* whenever a protected binary (like winetricks' /bin/sh)
    # is exec'd, so hand winetricks a wrapper that sets the Wine env itself
    # right before exec'ing the real wine binary. Per-invocation temp file:
    # a fixed path would be rewritten under a concurrent run's feet.
    local wrapper
    wrapper="$(mktemp "${HOME}/.cache/vineport/wine-env-wrapper-XXXXXX")"
    cat > "$wrapper" <<WRAP
#!/bin/bash
${wrapper_env}
exec "${wine_bin}" "\$@"
WRAP
    chmod +x "$wrapper"
    echo -e "${BOLD}winetricks $* ${NC}${DIM}(prefix: ${prefix})${NC}"
    # WINE_BIN/WINESERVER_BIN are winetricks' documented hints for wrapper
    # setups: they point at the REAL Mach-O binaries so its lipo-based arch
    # detection works (lipo can't type a shell-script WINE — fatal otherwise).
    local rc=0
    WINE="$wrapper" WINE_BIN="$wine_bin" WINESERVER="$wineserver_bin" \
        WINESERVER_BIN="$wineserver_bin" WINEPREFIX="$prefix" \
        WINEARCH=win64 PATH="$(dirname "$wine_bin"):${PATH}" \
        "${WINETRICKS_CACHE}" --unattended "$@" || rc=$?
    rm -f "$wrapper"
    return $rc
}

# ── Main ──────────────────────────────────────────────────────────────
init_profiles

case "${1:-}" in
    games|list|ls)
        list_games
        ;;
    launch|play|run)
        [[ -z "${2:-}" ]] && { echo "Usage: vineport launch <appid|name>"; exit 1; }
        appid=$(resolve_appid "$2")
        launch_game "$appid"
        ;;
    info|show)
        [[ -z "${2:-}" ]] && { echo "Usage: vineport info <appid|name>"; exit 1; }
        appid=$(resolve_appid "$2")
        show_info "$appid"
        ;;
    profile|config)
        [[ -z "${2:-}" ]] && { echo "Usage: vineport profile <appid> [--set KEY=VALUE | --reset]"; exit 1; }
        appid=$(resolve_appid "$2")
        shift 2
        show_profile "$appid" "$@"
        ;;
    steam)
        exec "${SCRIPT_DIR}/launch-steam.sh" "${@:2}"
        ;;
    tricks|winetricks)
        shift
        tricks_cmd "$@"
        ;;
    epic)
        shift
        handle_epic "$@"
        ;;
    help|--help|-h)
        usage
        ;;
    "")
        usage
        ;;
    *)
        echo -e "${RED}Unknown command: $1${NC}" >&2
        echo ""
        usage
        exit 1
        ;;
esac
